# Supabase Configuration
# Get these from your Supabase project dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App Configuration
NEXT_PUBLIC_APP_NAME="Money Control System"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Analytics (add if needed)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Finance Bot LLM fallback.
# The bot works FULLY FREE without any of the keys below — its built-in
# local engine handles data questions, affordability, budgets, net worth,
# calculations, and app help. A key only ADDS open-ended natural-language
# answers for anything the local engine can't handle.
#
# Set just ONE provider. They are tried in this order (free options first):
# GROQ, then GEMINI, then ANTHROPIC.
#
# Groq — FREE tier, get a key at https://console.groq.com
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
#
# Google Gemini — FREE tier, get a key at https://aistudio.google.com
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash
#
# Anthropic Claude — paid, get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
