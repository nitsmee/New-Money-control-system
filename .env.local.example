# Supabase Configuration
# Get these from your Supabase project dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App Configuration
NEXT_PUBLIC_APP_NAME="Money Control System"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Analytics (add if needed)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Finance Bot AI fallback (the app is fully free without this).
# The bot's built-in local engine handles data questions, affordability,
# calculations, and app help for free. Add your own Anthropic API key ONLY
# if you also want open-ended natural-language answers for anything else.
# Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
